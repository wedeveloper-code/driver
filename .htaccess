# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress

# ── Tri-County Driving Academy 301 Redirects ──
# Old static HTML URLs → new WordPress URLs (per PROJECT_PLAN.md)
<IfModule mod_rewrite.c>
RewriteEngine On

# Home page variants
RewriteRule ^index\.html$                                                     /                                           [R=301,L]
RewriteRule ^home\.htm$                                                       /                                           [R=301,L]
RewriteRule ^home\.html$                                                      /                                           [R=301,L]

# About Us
RewriteRule ^about-us\.htm$                                                   /about-us/                                  [R=301,L]
RewriteRule ^about-us\.html$                                                  /about-us/                                  [R=301,L]
RewriteRule ^about\.html$                                                     /about-us/                                  [R=301,L]
RewriteRule ^info/business-neighbors\.htm$                                    /about-us/                                  [R=301,L]
RewriteRule ^links\.html$                                                     /about-us/                                  [R=301,L]

# Programs overview
RewriteRule ^programs\.html$                                                  /training-programs/                         [R=301,L]
RewriteRule ^courses\.htm$                                                    /training-programs/                         [R=301,L]
RewriteRule ^courses\.html$                                                   /training-programs/                         [R=301,L]
RewriteRule ^courses/?$                                                       /training-programs/                         [R=301,L]

# CDL Class A
RewriteRule ^commercial-driver-training-class--a--cdl\.html$                 /commercial-driver-training-class-a-cdl/    [R=301,L]
RewriteRule ^Products/1(/.*)?$                                                /commercial-driver-training-class-a-cdl/    [R=301,L]
RewriteRule ^courses/tractor-trailer-training/?$                              /commercial-driver-training-class-a-cdl/    [R=301,L]

# Heavy Equipment
RewriteRule ^certified-heavy-equipment-training\.html$                       /certified-heavy-equipment-training/        [R=301,L]
RewriteRule ^Products/2(/.*)?$                                                /certified-heavy-equipment-training/        [R=301,L]
RewriteRule ^courses/heavy-equipment-training/?$                              /certified-heavy-equipment-training/        [R=301,L]
RewriteRule ^operator\.html$                                                  /certified-heavy-equipment-training/        [R=301,L]

# Diesel Mechanics
RewriteRule ^diesel-mechanics-heavy-truck-maintenance\.html$                 /diesel-mechanics-heavy-truck-maintenance/  [R=301,L]
RewriteRule ^Products/6(/.*)?$                                                /diesel-mechanics-heavy-truck-maintenance/  [R=301,L]
RewriteRule ^courses/diesel-school/?$                                         /diesel-mechanics-heavy-truck-maintenance/  [R=301,L]

# NCCER Training
RewriteRule ^nccer-training\.html$                                            /nccer-training/                            [R=301,L]
RewriteRule ^courses/nccer-training/?$                                        /nccer-training/                            [R=301,L]

# Driver Improvement
RewriteRule ^driver-improvement\.html$                                        /driver-improvement/                        [R=301,L]
RewriteRule ^driver\.html$                                                    /driver-improvement/                        [R=301,L]
RewriteRule ^courses/driver-improvement/?$                                    /driver-improvement/                        [R=301,L]
RewriteRule ^courses/virginia-online-driver-improvement/?$                    /driver-improvement/                        [R=301,L]

# Fiber Optics (old program — redirect to training programs overview)
RewriteRule ^fiber\.html$                                                     /training-programs/                         [R=301,L]
RewriteRule ^Products/3(/.*)?$                                                /training-programs/                         [R=301,L]
RewriteRule ^courses/fiber-optics-training/?$                                 /training-programs/                         [R=301,L]

# Surface Mining / OSHA / Hazmat (old programs)
RewriteRule ^Products/7(/.*)?$                                                /training-programs/                         [R=301,L]
RewriteRule ^Products/8(/.*)?$                                                /training-programs/                         [R=301,L]
RewriteRule ^Products/9(/.*)?$                                                /driver-improvement/                        [R=301,L]
RewriteRule ^courses/surface-mining-papers/?$                                 /training-programs/                         [R=301,L]
RewriteRule ^courses/osha-hazmat-training/?$                                  /training-programs/                         [R=301,L]

# Financial Aid / Admissions / Tuition
RewriteRule ^virginia-residents-financial-aid--pell-grant--packet\.html$     /financial-aid/                             [R=301,L]
RewriteRule ^info/tuition\.htm$                                               /admissions-funding/                        [R=301,L]
RewriteRule ^info/tuition/?$                                                  /admissions-funding/                        [R=301,L]

# Tennessee Student Information
RewriteRule ^info/info-for-tn-students\.htm$                                  /tennessee-student-information/             [R=301,L]
RewriteRule ^info/info-for-tn-students/?$                                     /tennessee-student-information/             [R=301,L]
RewriteRule ^tennessee-student-information\.html$                             /tennessee-student-information/             [R=301,L]

# Directions / Contact
RewriteRule ^directions\.htm$                                                 /contact-us/                                [R=301,L]
RewriteRule ^directions\.html$                                                /contact-us/                                [R=301,L]
RewriteRule ^directions/?$                                                    /contact-us/                                [R=301,L]
RewriteRule ^contact\.htm$                                                    /contact-us/                                [R=301,L]
RewriteRule ^contact\.html$                                                   /contact-us/                                [R=301,L]
RewriteRule ^contact-us\.html$                                                /contact-us/                                [R=301,L]

# News
RewriteRule ^our-news\.htm$                                                   /news/                                      [R=301,L]

# New pages (Our Fleet, Job Placement)
RewriteRule ^our-fleet\.html?$                                                /our-fleet/                                 [R=301,L]
RewriteRule ^job-placement\.html?$                                            /career-placement/                          [R=301,L]
RewriteRule ^career\.html?$                                                   /career-placement/                          [R=301,L]
RewriteRule ^fleet\.html?$                                                    /our-fleet/                                 [R=301,L]

</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-font-woff2 "access plus 1 year"
</IfModule>
